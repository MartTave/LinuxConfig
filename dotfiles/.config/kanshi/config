output "AU Optronics 0xE8B3 Unknown"  {
  mode 1920x1200@60
  scale 1
  alias $INTERNAL
}

output "HP Inc. HP E24 G4 CN422241GX" {
  mode 1920x1080@60
  scale 1
  alias $WORK_LEFT
}

output "Dell Inc. DELL P2417H CW6Y7744078B" {
  mode 1920x1080@60
  scale 1
  alias $WORK_RIGHT
}

profile work_external_only {
  output $INTERNAL disable
  output $WORK_LEFT {
    position 0,0
  }
  output $WORK_RIGHT {
    position 1920,0
  }
}

profile nomad {
  output $INTERNAL {
    position 0,0
  }
}
