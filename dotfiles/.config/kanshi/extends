profile work_extends {
  output $INTERNAL {
    position 0,880
  }
  output $WORK_RIGHT {
    position 2048,0
  }
  exec ~/.scripts/change_wacom_screen.sh "desc:Dell Inc. DELL P2723QE 55B6914"
  exec ~/.scripts/move_workspaces_to_screen.sh eDP-1 "desc:Dell Inc. DELL P2723QE 55B6914"
  exec sleep 2 && ~/.scripts/random_wp.sh
}

