[
  {
    "reload_style_on_change": true,
    "layer": "top",
    "position": "top",
    "margin-top": 0,
    "margin-bottom": 0,
    "margin-left": 4,
    "margin-right": 4,
    "space": 10,
    "modules-left": ["custom/rofi", "hyprland/workspaces", "hyprland/window"],
    "modules-center": ["clock"],
    "modules-right": [
      "network",
      "bluetooth",
      "cpu",
      "memory",
      "pulseaudio",
      "backlight",
      "battery",
    ],
    "custom/rofi": {
      "format": "\udb82\udcc7",
    },
    "hyprland/workspaces": {
      "all-outputs": true,
      "format": "{name}",
      "sort-by-number": true,
      "active-only": false,
    },
    "hyprland/window": {
      "format": "{title}",
      "separate-outputs": true,
      "rewrite": {
        "(.*) â€” Mozilla Firefox": "َ°ˆ¹  $1",
      },
    },
    "bluetooth": {
      "format-on": "<span class=\"icon\">ïٹ”</span",
      "format-disabled": "َ°‚²  ",
      "format-off": "َ°‚²  ",
      "format-connected": "َ°‚±  ",
      "tooltip-format": "{controller_alias}\t{controller_address}\n\n{num_connections} connected",
      "tooltip-format-connected": "{controller_alias}\t{controller_address}\n\n{num_connections} connected\n\n{device_enumerate}",
      "tooltip-format-enumerate-connected": "{device_alias}\t{device_address}",
      "tooltip-format-enumerate-connected-battery": "{device_alias}\t{device_address}\t{device_battery_percentage}%",
    },
    "clock": {
      "format": "ï€—  {:%a %e %b %H:%M}",
      "tooltip-format": "<tt>{calendar}</tt>",
      "calendar": {
        "mode": "month",
        "format": {
          "months": "<span color='#cdd6f4'><b>{}</b></span>",
          "days": "<span color='#cdd6f4'><b>{}</b></span>",
          "weeks": "<span color='#cdd6f4'><b>W{}</b></span>",
          "weekdays": "<span color='#cdd6f4'><b>{}</b></span>",
          "today": "<span color='#f38ba8'><b>{}</b></span>",
        },
      },
    },
    "network": {
      "format-wifi": "َ°¤¨",
      "format-ethernet": "َ°ˆ€",
      "format-disconnected": "َ°¤­",
      "tooltip-format-wifi": "{essid} ({signalStrength}%)",
      "tooltip-format-ethernet": "{ifname}: {ipaddr}/{cidr}",
      "tooltip-format-disconnected": "Disconnected",
    },
    "cpu": {
      "interval": 1,
      "format": "َ°کڑ {usage}%",
      "tooltip": true,
      "min-length": 6,
    },
    "memory": {
      "interval": 30,
      "format": "ï‘²  Mem {used}GiB",
      "tooltip": false,
      "min-length": 14,
    },
    "backlight": {
      "format": "{icon} <b>{percent}%</b>",
      "format-icons": ["َ°ƒ‍", "َ°ƒں", "َ°ƒ "],
      "tooltip": false,
    },
    "pulseaudio": {
      "format": "{icon} <b>{volume}%</b>",
      "format-muted": " َ°‌ں ",
      "format-bluetooth": "{icon} ïٹ” <b>{volume}%</b>",
      "format-bluetooth-muted": "َ°‌ں ïٹ”",
      "format-icons": {
        "headset": "ï€¥",
        "default": ["َ°•؟", "َ°–€", "َ°•¾"],
      },
      "tooltip": true,
      "on-click": "pavucontrol",
      "min-length": 6,
    },
    "battery": {
      "format": "{icon}  {capacity}%",
      "format-charging": "ï‡¦ {capacity}%",
      "format-icons": ["ï‰„", "ï‰ƒ", "ï‰‚", "ï‰پ", "ï‰€"],
      "max-length": 25,
      "tooltip": true,
      "interval": 5,
      "states": {
        "good": 70,
        "warning": 30,
        "critical": 15,
      },
    },
  },
]
