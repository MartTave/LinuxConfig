[
  {
    "reload_style_on_change": true,
    "layer": "top",
    "position": "top",
    "margin-top": 0,
    "margin-bottom": 0,
    "margin-left": 2,
    "margin-right": 2,
    "spacing": 15,
    "modules-left": ["custom/rofi", "hyprland/workspaces", "hyprland/window"],
    "modules-center": ["clock"],
    "modules-right": [
      "custom/sep1",
      "network",
      "bluetooth",
      "custom/sep1",
      "cpu",
      "memory",
      "custom/sep1",
      "pulseaudio",
      "backlight",
      "battery",
    ],
    "custom/rofi": {
      "format": "َ°£‡",
      "tooltip": false,
    },
    "hyprland/workspaces": {
      "all-outputs": true,
      "format": "{name}",
      "sort-by-number": true,
      "active-only": false,
    },
    "hyprland/window": {
      "format": "{title}",
      "separate-outputs": true,
      "rewrite": {
        "(.*) â€” Mozilla Firefox": "َ°ˆ¹  $1",
      },
    },
    "custom/sep1": {
      "format": "â”‚",
      "tooltip": false,
    },
    "bluetooth": {
      "format-on": "ïٹ”",
      "format-disabled": "َ°‚²",
      "format-off": "َ°‚²",
      "format-connected": "َ°‚±",
      "tooltip-format": "{controller_alias}\t{controller_address}\n\n{num_connections} connected",
      "tooltip-format-connected": "{controller_alias}\t{controller_address}\n\n{num_connections} connected\n\n{device_enumerate}",
      "tooltip-format-enumerate-connected": "{device_alias}\t{device_address}",
      "tooltip-format-enumerate-connected-battery": "{device_alias}\t{device_address}\t{device_battery_percentage}%",
      "min-length": 3,
      "on-click": "kitty -e bluetui",
    },
    "clock": {
      "format": "ï€—  {:%a %e %b %H:%M}",
      "tooltip-format": "<tt>{calendar}</tt>",
      "calendar": {
        "mode": "month",
        "format": {
          "months": "<span color='#cdd6f4'><b>{}</b></span>",
          "days": "<span color='#cdd6f4'><b>{}</b></span>",
          "weeks": "<span color='#cdd6f4'><b>W{}</b></span>",
          "weekdays": "<span color='#cdd6f4'><b>{}</b></span>",
          "today": "<span color='#f38ba8'><b>{}</b></span>",
        },
      },
    },
    "network#ethernet": {
      "format": "َ°ˆپ",
      "format-disconnected": "َ°ˆ‚",
      "tooltip-format": "{ifname}: {ipaddr}/{cidr}",
      "tooltip-format-disconnected": "Disconnected",
      "min-length": 3,
      "on-click": "kitty -e nmtui",
    },
    "network": {
      "format-wifi": "{icon}",
      "format-ethernet": "َ°ˆپ",
      "format-icons": ["َ°¤¯", "َ°¤ں", "َ°¤¢", "َ°¤¥", "َ°¤¨"],
      "format-disconnected": "َ°‡¨",
      "tooltip-format": "{essid} ({signalStrength}%)\n{ifname}: {ipaddr}/{cidr}",
      "tooltip-format-disconnected": "Disconnected",
      "min-length": 3,
      "on-click": "kitty -e nmtui",
    },
    "cpu": {
      "interval": 1,
      "format": "َ°کڑ {usage}%",
      "tooltip": true,
      "min-length": 6,
    },
    "memory": {
      "interval": 30,
      "format": "ï‘²  {used} GiB",
      "tooltip": true,
      "min-length": 14,
    },
    "backlight": {
      "format": "{icon}",
      "format-icons": ["َ°ƒ‍", "َ°ƒں", "َ°ƒ "],
      "tooltip": true,
      "min-length": 3,
      "tooltip-format": "{percent}%",
    },
    "pulseaudio": {
      "format": "{icon}",
      "format-muted": "َ°‌ں",
      "format-bluetooth": "{icon} ïٹ”",
      "format-bluetooth-muted": "َ°‌ں ïٹ”",
      "format-icons": {
        "headset": "ï€¥",
        "default": ["َ°•؟", "َ°–€", "َ°•¾"],
      },
      "tooltip": true,
      "tooltip-format": "{volume}%",
      "on-click": "pactl set-sink-mute @DEFAULT_SINK@ toggle",
      "min-length": 3,
    },
    "battery": {
      "format": "{icon}",
      "format-charging": "ï‡¦",
      "format-icons": ["ï‰„", "ï‰ƒ", "ï‰‚", "ï‰پ", "ï‰€"],
      "max-length": 25,
      "min-length": 6,
      "tooltip": true,
      "interval": 5,
      "states": {
        "good": 70,
        "warning": 30,
        "critical": 15,
      },
    },
  },
]
